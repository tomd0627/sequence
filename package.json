{
  "name": "sequence",
  "version": "1.0.0",
  "description": "Pressmark — a scroll-driven editorial experience built in vanilla HTML, CSS, and JS",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "serve": "npx serve src -l 3000",
    "lint:js": "eslint \"src/js/**/*.js\"",
    "lint:css": "stylelint \"src/css/**/*.css\"",
    "lint:format": "prettier --check .",
    "lint": "npm run lint:js && npm run lint:css && npm run lint:format",
    "format": "prettier --write .",
    "lighthouse": "npx lighthouse http://localhost:3000 --output=html --output-path=./lighthouse-report.html --chrome-flags=\"--headless\""
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "eslint": "^9.18.0",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0",
    "prettier": "^3.4.2",
    "stylelint": "^16.12.0",
    "stylelint-config-recess-order": "^5.1.1",
    "stylelint-config-standard": "^36.0.1",
    "stylelint-order": "^6.0.4"
  },
  "lint-staged": {
    "*.{html,css,js,json,md}": "prettier --write",
    "*.js": "eslint --fix",
    "*.css": "stylelint --fix"
  }
}
